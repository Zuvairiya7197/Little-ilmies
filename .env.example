# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/little_ilmies?schema=public"

# Auth.js / NextAuth
NEXTAUTH_SECRET="replace-with-a-random-32-byte-secret"
NEXTAUTH_URL="http://localhost:3000"

# Email (used for OTP / magic link buyer login and transactional emails)
EMAIL_SERVER_HOST=""
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="Little Ilmies <hello@littleilmies.com>"

# Razorpay (primary payment gateway)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# Optional payment gateways
STRIPE_SECRET_KEY=""
PAYPAL_CLIENT_ID=""

# Site
SITE_URL="http://localhost:3000"

# Local private storage (full PDFs, previews, covers live outside /public)
PRIVATE_UPLOADS_DIR="./private-uploads"
